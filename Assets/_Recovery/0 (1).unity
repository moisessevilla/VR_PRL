--- !u!114 &1811847687
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 1811847685}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: 78854a22f8fb80043b55def3314fba9a, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::SecuenciaRiesgos
  riesgos:
  - id: Incendio
    puntoGuia: {fileID: 1126771064}
    mensaje: Fuego!! Riesgo de incendio, busca un extintor y apaga el fuego!!
    cantidadRequerida: 1
    mensajeInicio: Dirigete al punto marcado.
  - id: Intoxicacion
    puntoGuia: {fileID: 1593933284}
    mensaje: "Riesgo desconocido. \xA1No entrar bajo ning\xFAn concepto!"
    cantidadRequerida: 1
    mensajeInicio: 
  - id: Aceite
    puntoGuia: {fileID: 85336014}
    mensaje: "Bid\xF3n volcado con derrame de aceite. Riesgo de resbal\xF3n y ca\xEDda.
      Coge las balizas de suelo h\xFAmedo y col\xF3cala sobre las zonas marcadas
      junto al derrame."
    cantidadRequerida: 2
    mensajeInicio: Dirigete al punto marcado.
  - id: Tropiezo
    puntoGuia: {fileID: 1491810177}
    mensaje: "Objetos sueltos en el suelo, riesgo de tropiezo. Rec\xF3ge 3 objetos
      y col\xF3calos sobre el carro de herramientas."
    cantidadRequerida: 3
    mensajeInicio: Dirigete al punto marcado.
  - id: Electrico
    puntoGuia: {fileID: 1024491023}
    mensaje: "Atenci\xF3n!! Riesgo el\xE9ctrico, cables sueltos, m\xE1quina con tensi\xF3n
      220V. Acordona la zona y pon una se\xF1al de riesgo el\xE9ctrico en la puerta
      de acceso."
    cantidadRequerida: 4
    mensajeInicio: Dirigete al punto marcado.
  - id: Bloqueo
    puntoGuia: {fileID: 634574128}
    mensaje: "Precauci\xF3n!! Escaleras sin barandilla, peligro de ca\xEDda a diferentes
      alturas. Cajas bloqueando el acceso a la planta superior. Ap\xE1rtalas para
      despejar el paso."
    cantidadRequerida: 2
    mensajeInicio: Dirigete al punto marcado.
  texto: {fileID: 328153849}
  panelHUD: {fileID: 111567211}
  sonidoBeep: {fileID: 1776011333}
  sonidoOK: {fileID: 206784063}
  sonidoWin: {fileID: 2047909682}
  lineaGuia: {fileID: 818252071}
